# --- OS / editor ---
.DS_Store
.DS_Store?
._*

# --- Python ---
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/
dist/
build/

# --- Secrets / local config ---
.env
# Local MCP server config (machine-specific paths + personal mailto).
.mcp.json
# Claude Code's local skill/plugin symlinks (source of truth lives in
# src/autocodabench/skills/ and experiments/; recreate with setup.sh).
.claude/

# --- autocodabench runtime artifacts ---
# Workspace root for runs + bundles (AUTOCODABENCH_HOME default).
.autocodabench/
# Default output dir of `autocodabench demo`.
autocodabench-demo/
logs/

# --- Experiment harness ---
# Per-run output dirs are covered by experiments/bundle_creation_test/runs/.gitignore.
# Reference PDFs (competition proposals) are kept outside git.
*.pdf

# --- Web UI runtime ---
.chainlit/
# Chainlit local per-session attachment cache (auto-created next to web/).
web/.files/
# Per-session web runtime artifacts (manifest/plan/transcript/bundle HTML+zip).
# Written at runtime by web/app.py; never source.
web/public/sessions/


experiments/bundle_creation_test/runs/*/
