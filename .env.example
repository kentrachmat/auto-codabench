# autocodabench environment variables. Copy to .env (gitignored).

# ---------------------------------------------------------------------------
# Claude auth — pick ONE path.
#
# Local dev (recommended): no variable at all. Log in to Claude Code
# (`claude` → /login) and the Agent SDK uses your Pro/Max subscription;
# usage draws from the plan's monthly Agent SDK credit.
#
# Hosted / multi-user deployments (e.g. the HF Space) MUST use an API key —
# routing other users' requests through one person's subscription violates
# Anthropic's terms. NOTE: an exported ANTHROPIC_API_KEY silently overrides
# a subscription login (`autocodabench auth status` warns about this).
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=

# Optional: your own Kaggle API token for Phase-1 competition research. Without
# it, a shared throw-away token is used for PUBLIC reads. Generate one at
# https://www.kaggle.com/settings/api (or place ~/.kaggle/kaggle.json).
# KAGGLE_API_TOKEN=

# OpenAlex polite pool — required for alex-mcp (web UI only). Any real email.
OPENALEX_MAILTO=you@email.com

# Optional overrides for where artifacts live (default: ./.autocodabench/).
# AUTOCODABENCH_HOME=
# AUTOCODABENCH_BUNDLES_ROOT=
# AUTOCODABENCH_RUNS_ROOT=

# Codabench upload credentials (consumed by autocodabench_upload_bundle and
# the `python -m autocodabench.upload.codabench_api` CLI).
# WARNING: anyone who can drive the autocodabench MCP server with these set
# can publish competitions on this account. Do not commit. Do not deploy a
# public web UI with these baked in unless you have a per-user auth layer.
CODABENCH_BASE_URL=https://www.codabench.org
CODABENCH_USERNAME=
CODABENCH_PASSWORD=
